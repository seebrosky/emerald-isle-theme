{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "emerald-isle/featured-article-card",
  "version": "1.0.0",
  "title": "Featured Article Card",
  "category": "widgets",
  "icon": "media-document",
  "description": "Display a featured article card with image, category, headline, excerpt, and call-to-action.",
  "keywords": [
    "article",
    "featured",
    "card",
    "news",
    "content"
  ],
  "textdomain": "emerald-isle",
  "editorScript": "file:./build/index.js",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": ""
    },
    "headline": {
      "type": "string",
      "default": ""
    },
    "excerpt": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": "Read More"
    },
    "buttonUrl": {
      "type": "string",
      "default": ""
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageId": {
      "type": "number"
    },
    "layout": {
      "type": "string",
      "default": "stacked"
    }
  },
  "supports": {
    "html": false
  }
}