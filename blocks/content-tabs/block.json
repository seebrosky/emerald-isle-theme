{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "emerald-isle/content-tabs",
	"title": "Content Tabs",
	"category": "design",
	"icon": "index-card",
	"description": "A tabbed content component built with React.",
	"supports": {
		"html": false
	},
	"editorScript": "file:./build/index.js",
    "viewScript": "file:./view.js",
	"style": "file:./style.css",
	"editorStyle": "file:./editor.css",
    "attributes": {
        "tabs": {
            "type": "array",
            "default": [
                {
                    "label": "Overview",
                    "heading": "Overview Heading",
                    "description": "Overview content.",
                    "buttonText": "Learn More",
                    "buttonUrl": "#"
                }
            ]
        },
        "layout": {
            "type": "string",
            "default": "horizontal"
        }        
    }
}